# ============================================================
#  Youth SACCO Backend — Environment Variables
#  Copy this file to '.env' and fill in your real values.
# ============================================================

# ----------------------------------------------------------
# DATABASE (choose ONE of the options below)
# ----------------------------------------------------------

# OPTION A — Full connection URL (used by Render / PlanetScale / Railway)
# Format: mysql+pymysql://user:password@host:port/dbname
# Leave blank if using individual vars (Option B)
DATABASE_URL=

# OPTION B — Individual MySQL credentials (for local dev)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sacco_db

# ----------------------------------------------------------
# APP SECURITY
# ----------------------------------------------------------
SECRET_KEY=change-this-to-a-long-random-string

# ----------------------------------------------------------
# SMTP — Email for MFA codes and password-reset links
# Leave blank to print codes to the console instead.
# ----------------------------------------------------------
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_google_app_password
SMTP_FROM=noreply@youthsacco.com
